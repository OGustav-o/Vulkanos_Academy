@page "/profile/{userId:guid}"
@using VulkanosAcademy.Domain.DTOs
@using VulkanosAcademy.Web.Services
@inject IGamificationService GamificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-1">Perfil do Usuário</h1>
            <p class="text-muted">Suas conquistas e progresso na Vulkanos Academy</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Carregando perfil...
        </div>
    }
    else if (userProfile == null)
    {
        <div class="alert alert-danger">
            <span class="bi bi-exclamation-triangle me-2"></span>
            Erro ao carregar perfil ou perfil não encontrado.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card profile-card">
                    <div class="card-body text-center">
                        <img src="/images/avatar.png" class="profile-avatar mb-3" alt="Avatar" />
                        <h4 class="card-title">@userProfile.FirstName @userProfile.LastName</h4>
                        <p class="text-muted">@userProfile.Title</p>
                        <hr />
                        <div class="xp-level-info">
                            <p class="mb-1">XP Total: <strong>@userProfile.TotalXP</strong></p>
                            <p class="mb-0">Nível: <strong>@userProfile.CurrentLevel</strong></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8 mb-4">
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Minhas Conquistas (Badges)</h5>
                    </div>
                    <div class="card-body">
                        @if (userProfile.Badges != null && userProfile.Badges.Any())
                        {
                            <div class="row">
                                @foreach (var userBadge in userProfile.Badges)
                                {
                                    <div class="col-6 col-md-4 col-lg-3 mb-3">
                                        <div class="badge-item text-center">
                                            <img src="@userBadge.Badge?.IconUrl" class="badge-icon mb-2" alt="@userBadge.Badge?.Name" />
                                            <h6>@userBadge.Badge?.Name</h6>
                                            <small class="text-muted">@userBadge.EarnedAt.ToString("dd/MM/yyyy")</small>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">Nenhuma conquista ainda. Continue aprendendo para ganhar suas primeiras medalhas!</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .profile-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        padding: 20px;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #FF6600;
        box-shadow: 0 0 0 6px rgba(255, 102, 0, 0.2);
    }

    .xp-level-info p {
        font-size: 1.1rem;
    }

    .badge-item {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 15px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s ease;
    }

    .badge-item:hover {
        transform: translateY(-3px);
    }

    .badge-icon {
        width: 60px;
        height: 60px;
        object-fit: contain;
    }
</style>

@code {
    [Parameter]
    public Guid UserId { get; set; }

    private UserProfileDto? userProfile;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserProfile();
    }

    private async Task LoadUserProfile()
    {
        isLoading = true;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdClaim = user.FindFirst("sub")?.Value ?? user.FindFirst("nameid")?.Value;
                if (Guid.TryParse(userIdClaim, out var currentUserId))
                {
                    // Apenas o próprio usuário ou um admin pode ver o perfil completo
                    if (currentUserId == UserId || user.IsInRole("Admin"))
                    {
                        userProfile = await GamificationService.GetUserProfileAsync(UserId);
                    }
                    else
                    {
                        Navigation.NavigateTo("/unauthorized"); // Redirecionar para página de não autorizado
                    }
                }
            }
            else
            {
                Navigation.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar perfil do usuário: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
