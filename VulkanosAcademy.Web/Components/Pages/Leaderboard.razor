@page "/leaderboard"
@using VulkanosAcademy.Domain.DTOs
@using VulkanosAcademy.Web.Services
@inject IGamificationService GamificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-1">Ranking de Alunos</h1>
            <p class="text-muted">Veja quem está no topo da Vulkanos Academy!</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Carregando ranking...
        </div>
    }
    else if (leaderboard == null || !leaderboard.Any())
    {
        <div class="alert alert-warning">
            <span class="bi bi-exclamation-triangle me-2"></span>
            Nenhum aluno no ranking ainda. Seja o primeiro a aparecer!
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">Top Alunos por XP</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover leaderboard-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nome</th>
                                <th>Nível</th>
                                <th>Título</th>
                                <th>XP Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in leaderboard.Select((item, index) => new { Item = item, Index = index }))
                            {
                                <tr class="@(entry.Item.UserId == currentUserId ? "table-primary" : "")">
                                    <td>@(entry.Index + 1)</td>
                                    <td>
                                        <a href="/profile/@entry.Item.UserId" class="text-decoration-none">
                                            @entry.Item.UserName
                                        </a>
                                    </td>
                                    <td>@entry.Item.CurrentLevel</td>
                                    <td>@entry.Item.Title</td>
                                    <td>@entry.Item.TotalXP</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .leaderboard-table th {
        background-color: #f0f2f5;
        color: #333;
        font-weight: 600;
    }

    .leaderboard-table tbody tr:nth-child(1) {
        background-color: #FFD70030; /* Ouro */
        font-weight: bold;
    }

    .leaderboard-table tbody tr:nth-child(2) {
        background-color: #C0C0C030; /* Prata */
    }

    .leaderboard-table tbody tr:nth-child(3) {
        background-color: #CD7F3230; /* Bronze */
    }

    .leaderboard-table tbody tr.table-primary {
        background-color: #e0f7fa !important;
        font-weight: bold;
    }
</style>

@code {
    private IEnumerable<LeaderboardEntryDto>? leaderboard;
    private bool isLoading = true;
    private Guid currentUserId;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthorization();
        await LoadLeaderboard();
    }

    private async Task CheckAuthorization()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login");
        }

        var userIdClaim = user.FindFirst("sub")?.Value ?? user.FindFirst("nameid")?.Value;
        if (Guid.TryParse(userIdClaim, out var userId))
        {
            currentUserId = userId;
        }
    }

    private async Task LoadLeaderboard()
    {
        isLoading = true;
        try
        {
            leaderboard = await GamificationService.GetLeaderboardAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar leaderboard: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
