@page "/login"
@using VulkanosAcademy.Domain.DTOs
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h2 class="card-title text-center mb-4">Entrar na Vulkanos Academy</h2>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    <form @onsubmit="HandleLogin">
                        <div class="mb-3">
                            <label for="email" class="form-label">E-mail</label>
                            <input type="email" class="form-control" id="email" @bind="loginDto.Email" required />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Senha</label>
                            <input type="password" class="form-control" id="password" @bind="loginDto.Password" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Entrando...</span>
                            }
                            else
                            {
                                <span>Entrar</span>
                            }
                        </button>
                    </form>

                    <hr class="my-4" />

                    <p class="text-center">
                        Não tem conta? <a href="/register">Registre-se aqui</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginDto loginDto = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;

        var result = await AuthService.LoginAsync(loginDto);
        if (result != null)
        {
            await AuthService.SetTokenAsync(result.Token);
            Navigation.NavigateTo("/dashboard");
        }
        else
        {
            errorMessage = "Email ou senha inválidos";
        }

        isLoading = false;
    }
}
